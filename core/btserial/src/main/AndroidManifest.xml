<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      Bluetooth-serial (SPP) console (#406). BLUETOOTH_CONNECT (API 31+) covers both
      listing bonded devices and opening the RFCOMM socket; the legacy BLUETOOTH
      permission is the pre-31 equivalent. No scanning — pairing is done in Android
      Settings — so BLUETOOTH_SCAN is deliberately not requested.
      Declared here, in the module that uses Bluetooth, so the app inherits it via
      manifest merge rather than relying on an unrelated module's manifest (which
      the app does NOT actually depend on — #406 device test caught the gap).
    -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="false" />
</manifest>
